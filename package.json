{
  "name": "ngx-json-editor",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve playground",
    "build": "ng build ngx-json-editor && ng build playground",
    "build:lib": "ng build ngx-json-editor && npm run build:schematics",
    "build:schematics": "tsc -p projects/ngx-json-editor/schematics/tsconfig.json && node -e \"require('fs').copyFileSync('projects/ngx-json-editor/schematics/collection.json','dist/ngx-json-editor/schematics/collection.json')\"",
    "build:lib:watch": "ng build ngx-json-editor --watch --configuration development",
    "build:playground": "ng build playground",
    "docs": "compodoc -p projects/ngx-json-editor/tsconfig.lib.json -n \"ngx-json-editor\" -d dist/docs --hideGenerator",
    "bundlesize": "node scripts/check-bundle-size.js",
    "watch": "ng build ngx-json-editor --watch --configuration development",
    "test": "npm run test:core && npm run test:lib",
    "test:core": "ng test ngx-json-editor-core --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:lib": "ng test ngx-json-editor --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:playground": "ng test playground --watch=false --browsers=ChromeHeadless",
    "pack:lib": "npm run build:lib && cd dist/ngx-json-editor && npm pack",
    "lint": "eslint .",
    "format": "prettier --write \"projects/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss}\"",
    "typecheck": "tsc -p projects/ngx-json-editor/tsconfig.lib.json --noEmit --inlineSources false --sourceMap false && tsc -p projects/playground/tsconfig.app.json --noEmit"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.25",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@primeng/themes": "^20.4.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "codemirror": "^6.0.2",
    "jmespath": "^0.16.0",
    "primeicons": "^7.0.0",
    "primeng": "^20.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.3",
    "@angular/cli": "^20.3.3",
    "@angular/compiler-cli": "^20.3.0",
    "@eslint/js": "^9.39.4",
    "@types/jasmine": "~5.1.0",
    "@types/jmespath": "^0.15.2",
    "angular-eslint": "^20.7.0",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.61.1"
  }
}
