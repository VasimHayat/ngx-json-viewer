    "url": "git+https://github.com/VasimHayat/ngx-json-viewer.git"
  },
  "homepage": "https://github.com/VasimHayat/ngx-json-viewer#readme",
  "bugs": {
    "url": "https://github.com/VasimHayat/ngx-json-viewer/issues"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@angular/common": "^20.0.0 || ^21.0.0",
    "@angular/core": "^20.0.0 || ^21.0.0",
