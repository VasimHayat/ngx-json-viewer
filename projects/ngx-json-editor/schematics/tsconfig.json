{
  "compilerOptions": {
    "lib": ["es2022"],
    "declaration": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "strict": true,
    "outDir": "../../../dist/ngx-json-editor/schematics",
    "rootDir": ".",
    "skipLibCheck": true,
    "target": "es2022",
    "types": []
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
